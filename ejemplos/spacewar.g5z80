%% ================================================================
   SPACEWAR  -  Claude contra los asteroides
   Grupo 5 - Lenguaje Dummy  ->  Amstrad CPC (WinAPE)

   Pilotas al muneco de Claude en la parte inferior y disparas a los
   asteroides, que aparecen en TRES tamanos distintos. Destruir uno
   da mas puntos cuanto mas grande; si te golpea pierdes una vida.
   Con 0 vidas: GAME OVER. El juego acelera con el tiempo.

   CONTROLES (3 teclas):
       O  = mover a la izquierda
       P  = mover a la derecha
       ESPACIO = disparar

   Sprites (caracteres definidos por el usuario, via sprites()):
       240 = muneco de Claude (nave)
       241 = asteroide pequeno   242 = mediano   243 = grande
   ================================================================ %%
inicio {
  num nave = 20;      %% columna de la nave (1..40)              %%
  num ax = 10;        %% columna del asteroide                    %%
  num ay = 1;         %% fila del asteroide                       %%
  num tam = 1;        %% tamano del asteroide (1..3)              %%
  num bx = 0;         %% columna de la bala                       %%
  num by = 0;         %% fila de la bala                          %%
  num bactivo = 0;    %% 1 si hay una bala en vuelo               %%
  num score = 0;      %% puntaje                                  %%
  num vidas = 3;      %% vidas restantes                          %%
  num vel = 14;       %% cuadros por bajada (menor = mas rapido)  %%
  num t = 0;          %% temporizador de caida                    %%
  num k = 0;          %% tecla leida                              %%
  num jugando = 1;    %% 1 mientras el juego sigue                %%

  sprites();          %% define al muneco de Claude y los asteroides %%

  %% ---------------- Pantalla de titulo ---------------- %%
  limpiar();
  posicionar(13, 3);
  dibujar("S P A C E W A R");
  posicionar(6, 6);
  dibujar("O = izq   P = der   ESPACIO = disparar");
  posicionar(4, 9);
  dibujar("Claude: ");
  pintar(240);
  posicionar(4, 11);
  dibujar("Asteroides: ");
  pintar(241);
  dibujar(" ");
  pintar(242);
  dibujar(" ");
  pintar(243);
  posicionar(8, 14);
  dibujar("Preparate...");
  esperar(150);

  %% primer asteroide: columna (2..39) y tamano (1..3) al azar %%
  ax = aleatorio(38) + 2;
  tam = aleatorio(3) + 1;
  limpiar();

  %% ================= BUCLE PRINCIPAL ================= %%
  loop (jugando == 1) {

    %% --- Entrada de teclado (no bloqueante) --- %%
    k = tecla();

    %% O = izquierda (acepta mayuscula y minuscula) %%
    cuando (k == 111 || k == 79) {
      cuando (nave > 1) {
        posicionar(nave, 23);
        dibujar(" ");
        nave = nave - 1;
      }
    }
    %% P = derecha %%
    cuando (k == 112 || k == 80) {
      cuando (nave < 40) {
        posicionar(nave, 23);
        dibujar(" ");
        nave = nave + 1;
      }
    }
    %% ESPACIO = disparar (solo si no hay bala en vuelo) %%
    cuando (k == 32) {
      cuando (bactivo == 0) {
        bactivo = 1;
        bx = nave;
        by = 22;
      }
    }

    %% --- Movimiento de la bala (sube cada cuadro) --- %%
    cuando (bactivo == 1) {
      posicionar(bx, by);
      dibujar(" ");
      by = by - 1;
      cuando (by < 1) {
        bactivo = 0;
      }
      %% impacto bala-asteroide (misma columna y fila) %%
      cuando (bactivo == 1) {
        cuando (bx == ax) {
          cuando (by == ay) {
            score = score + tam + 2;      %% grande = mas puntos %%
            bactivo = 0;
            posicionar(ax, ay);
            dibujar(" ");
            ay = 1;
            ax = aleatorio(38) + 2;
            tam = aleatorio(3) + 1;
            cuando (vel > 5) {
              vel = vel - 1;
            }
          }
        }
      }
    }

    %% --- Avance del asteroide segun el temporizador --- %%
    t = t + 1;
    cuando (t >= vel) {
      t = 0;
      posicionar(ax, ay);
      dibujar(" ");
      ay = ay + 1;

      %% fila de la nave (23): comprobar choque %%
      cuando (ay == 23) {
        cuando (ax == nave) {
          vidas = vidas - 1;
          cuando (vidas < 1) {
            jugando = 0;
          }
        }
      }
      %% paso el fondo: reaparece arriba con nuevo tamano %%
      cuando (ay > 23) {
        ay = 1;
        ax = aleatorio(38) + 2;
        tam = aleatorio(3) + 1;
        score = score + 1;
        cuando (vel > 5) {
          vel = vel - 1;
        }
      }
    }

    %% --- Dibujo de la escena --- %%
    posicionar(ax, ay);
    pintar(240 + tam);                  %% asteroide segun su tamano %%

    cuando (bactivo == 1) {
      posicionar(bx, by);
      pintar(124);                      %% '|' = bala %%
    }

    posicionar(nave, 23);
    pintar(240);                        %% muneco de Claude %%

    %% marcador (fila 1) %%
    posicionar(1, 1);
    dibujar("Score: ");
    dibujar(score);
    dibujar("   Vidas: ");
    dibujar(vidas);
    dibujar(" ");

    %% ritmo del juego %%
    esperar(2);
  }

  %% ================= FIN DEL JUEGO ================= %%
  limpiar();
  posicionar(16, 10);
  dibujar("GAME OVER");
  posicionar(12, 13);
  dibujar("Puntaje final: ");
  dibujar(score);
  posicionar(6, 16);
  dibujar("Grupo 5 - Lenguajes y Compiladores");
}
